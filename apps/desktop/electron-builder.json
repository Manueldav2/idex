{
  "appId": "com.devvcore.idex",
  "productName": "IDEX",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json",
    "!**/node_modules/@idex/**",
    "!**/node_modules/.pnpm/@idex+**"
  ],
  "asar": true,
  "asarUnpack": ["**/node_modules/node-pty/**/*", "**/node_modules/keytar/**/*"],
  "mac": {
    "category": "public.app-category.developer-tools",
    "target": [
      { "target": "dmg", "arch": ["arm64"] },
      { "target": "zip", "arch": ["arm64"] }
    ],
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "darkModeSupport": true,
    "type": "distribution",
    "identity": null
  },
  "dmg": {
    "title": "IDEX ${version}",
    "iconSize": 96,
    "window": { "width": 540, "height": 380 },
    "contents": [
      { "x": 130, "y": 220, "type": "file" },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  },
  "publish": null
}
