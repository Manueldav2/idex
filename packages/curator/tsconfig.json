{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@idex/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src/**/*", "src/**/*.json"],
  "comment": "Evals run under vitest/tsx (own transpile + vitest globals), not the library tsc build.",
  "exclude": ["src/__evals__"]
}
